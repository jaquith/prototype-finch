{
  "name": "builder-ui-kit",
  "private": false,
  "version": "1.0.0",
  "description": "Builder UI Component Library",
  "main": "dist/src/index.cjs.js",
  "module": "dist/src/index.esm.js",
  "homepage": "https://github.com/dasia-benson/builder-ui-kit",
  "issues": "https://github.com/dasia-benson/builder-ui-kit/issues",
  "keywords": [
    "react",
    "tealium",
    "ui-kit",
    "builder"
  ],
  "files": [
    "dist",
    "ui-kit-adapter"
  ],
  "exports": {
    ".": "./dist/src/index.cjs.js",
    "./ui-kit-adapter": "./ui-kit-adapter/index.js"
  },
  "scripts": {
    "build-storybook": "storybook build --quiet --webpack-stats-json ./storybook-static",
    "build": "rm -rf dist && rollup -c",
    "lint:check": "eslint src/. --ext .js,.jsx",
    "lint:fix": "eslint src/. --ext .js,.jsx --fix",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "storybook": "storybook dev -p 6006",
    "styles:check": "stylelint './src/**/*.(js|jsx)'",
    "test:watch": "jest --watch",
    "test:axe": "concurrently --kill-others --success first \"start-storybook -p 6006\" \"wait-on http://localhost:6006 && test-storybook\"",
    "test:axe:ci": "GIT_DIFF_RANGE='origin/main...HEAD' npm run test:axe",
    "pw:install": "npx playwright install chromium",
    "test": "jest --coverage",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dasia-benson/builder-ui-kit.git",
    "baseUrl": "https://github.com/dasia-benson/builder-ui-kit"
  },
  "publishConfig": {
    "registry": "https://tealium.jfrog.io/artifactory/api/npm/npm-local/",
    "tag": "latest"
  },
  "author": {
    "name": "Builder - Tealium Team"
  },
  "license": "ISC",
